{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "timezone": "Europe/Berlin",
  "schedule": ["before 6am on monday"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 6,
  "labels": ["renovate", "dependencies"],
  "packageRules": [
    {
      "description": "Group all Python dependencies",
      "matchManagers": ["pep621", "pip_requirements", "pip_setup"],
      "groupName": "python dependencies"
    },
    {
      "description": "Separate group for test/dev tools",
      "matchManagers": ["pep621", "pip_requirements"],
      "matchPackageNames": ["pytest", "mypy", "ruff", "black", "pyinstaller"],
      "matchPackagePatterns": ["^pytest-", "^pytest_"],
      "groupName": "python dev tools"
    }
  ]
}
